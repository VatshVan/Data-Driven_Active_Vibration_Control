<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="platform_world">

    <!-- ==================== PHYSICS ==================== -->
    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ==================== WORLD PLUGINS ==================== -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics">
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
    </plugin>

    <!-- ==================== LIGHTING ==================== -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ==================== GROUND PLANE ==================== -->
    <model name="ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!--              VIBRATION PLATFORM WITH 4 ACTUATORS             -->
    <!-- ============================================================ -->
    <model name="vibration_platform">

      <!-- ======= BASE FRAME (Ceiling/Mount - Fixed to World) ======= -->
      <link name="base_link">
        <pose>0 0 3.0 0 0 0</pose>
        <visual name="base_visual">
          <geometry>
            <box>
              <size>1.2 1.0 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
          </material>
        </visual>
        <collision name="base_collision">
          <geometry>
            <box>
              <size>1.2 1.0 0.05</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>1000.0</mass>
          <inertia>
            <ixx>100.0</ixx>
            <iyy>100.0</iyy>
            <izz>100.0</izz>
          </inertia>
        </inertial>
      </link>

      <joint name="world_to_base" type="fixed">
        <parent>world</parent>
        <child>base_link</child>
      </joint>

      <!-- ======= ACTUATOR FL (Front-Left) ======= -->
      <link name="actuator_fl">
        <pose>0.5 0.4 2.0 0 0 0</pose>
        <visual name="visual_fl">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
          <material>
            <ambient>1.0 0.0 0.0 1</ambient>
            <diffuse>1.0 0.0 0.0 1</diffuse>
          </material>
        </visual>
        <collision name="collision_fl">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>3.0</mass>
          <inertia>
            <ixx>0.01125</ixx>
            <iyy>0.01125</iyy>
            <izz>0.01125</izz>
          </inertia>
        </inertial>
      </link>

      <joint name="spring_fl" type="prismatic">
        <parent>base_link</parent>
        <child>actuator_fl</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-2.0</lower>
            <upper>1.0</upper>
            <effort>1000</effort>
            <velocity>10</velocity>
          </limit>
          <dynamics>
            <spring_stiffness>200.0</spring_stiffness>
            <spring_reference>-1.0</spring_reference>
            <damping>10.0</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- ======= ACTUATOR FR (Front-Right) ======= -->
      <link name="actuator_fr">
        <pose>0.5 -0.4 2.0 0 0 0</pose>
        <visual name="visual_fr">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
          <material>
            <ambient>0.0 1.0 0.0 1</ambient>
            <diffuse>0.0 1.0 0.0 1</diffuse>
          </material>
        </visual>
        <collision name="collision_fr">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>3.0</mass>
          <inertia>
            <ixx>0.01125</ixx>
            <iyy>0.01125</iyy>
            <izz>0.01125</izz>
          </inertia>
        </inertial>
      </link>

      <joint name="spring_fr" type="prismatic">
        <parent>base_link</parent>
        <child>actuator_fr</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-2.0</lower>
            <upper>1.0</upper>
            <effort>1000</effort>
            <velocity>10</velocity>
          </limit>
          <dynamics>
            <spring_stiffness>200.0</spring_stiffness>
            <spring_reference>-1.0</spring_reference>
            <damping>10.0</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- ======= ACTUATOR RL (Rear-Left) ======= -->
      <link name="actuator_rl">
        <pose>-0.5 0.4 2.0 0 0 0</pose>
        <visual name="visual_rl">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
          <material>
            <ambient>0.0 0.0 1.0 1</ambient>
            <diffuse>0.0 0.0 1.0 1</diffuse>
          </material>
        </visual>
        <collision name="collision_rl">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>3.0</mass>
          <inertia>
            <ixx>0.01125</ixx>
            <iyy>0.01125</iyy>
            <izz>0.01125</izz>
          </inertia>
        </inertial>
      </link>

      <joint name="spring_rl" type="prismatic">
        <parent>base_link</parent>
        <child>actuator_rl</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-2.0</lower>
            <upper>1.0</upper>
            <effort>1000</effort>
            <velocity>10</velocity>
          </limit>
          <dynamics>
            <spring_stiffness>200.0</spring_stiffness>
            <spring_reference>-1.0</spring_reference>
            <damping>10.0</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- ======= ACTUATOR RR (Rear-Right) ======= -->
      <link name="actuator_rr">
        <pose>-0.5 -0.4 2.0 0 0 0</pose>
        <visual name="visual_rr">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
          <material>
            <ambient>1.0 1.0 0.0 1</ambient>
            <diffuse>1.0 1.0 0.0 1</diffuse>
          </material>
        </visual>
        <collision name="collision_rr">
          <geometry>
            <box>
              <size>0.15 0.15 0.15</size>
            </box>
          </geometry>
        </collision>
        <inertial>
          <mass>3.0</mass>
          <inertia>
            <ixx>0.01125</ixx>
            <iyy>0.01125</iyy>
            <izz>0.01125</izz>
          </inertia>
        </inertial>
      </link>

      <joint name="spring_rr" type="prismatic">
        <parent>base_link</parent>
        <child>actuator_rr</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-2.0</lower>
            <upper>1.0</upper>
            <effort>1000</effort>
            <velocity>10</velocity>
          </limit>
          <dynamics>
            <spring_stiffness>200.0</spring_stiffness>
            <spring_reference>-1.0</spring_reference>
            <damping>10.0</damping>
            <friction>0.0</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- ======= VISUAL PLATFORM (Connecting the 4 actuators visually) ======= -->
      <link name="platform_visual">
        <pose>0 0 2.0 0 0 0</pose>
        <visual name="platform_vis">
          <geometry>
            <box>
              <size>1.0 0.8 0.03</size>
            </box>
          </geometry>
          <material>
            <ambient>0.0 1.0 1.0 0.5</ambient>
            <diffuse>0.0 1.0 1.0 0.5</diffuse>
          </material>
        </visual>
        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.001</ixx>
            <iyy>0.001</iyy>
            <izz>0.001</izz>
          </inertia>
        </inertial>
      </link>

      <joint name="platform_attach" type="fixed">
        <parent>actuator_fl</parent>
        <child>platform_visual</child>
      </joint>

      <!-- ======= PLUGINS ======= -->
      
      <!-- Joint State Publisher (all 4 joints) -->
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <joint_name>spring_fl</joint_name>
        <joint_name>spring_fr</joint_name>
        <joint_name>spring_rl</joint_name>
        <joint_name>spring_rr</joint_name>
      </plugin>

      <!-- Apply Force: FL -->
      <plugin filename="gz-sim-apply-joint-force-system"
              name="gz::sim::systems::ApplyJointForce">
        <joint_name>spring_fl</joint_name>
      </plugin>

      <!-- Apply Force: FR -->
      <plugin filename="gz-sim-apply-joint-force-system"
              name="gz::sim::systems::ApplyJointForce">
        <joint_name>spring_fr</joint_name>
      </plugin>

      <!-- Apply Force: RL -->
      <plugin filename="gz-sim-apply-joint-force-system"
              name="gz::sim::systems::ApplyJointForce">
        <joint_name>spring_rl</joint_name>
      </plugin>

      <!-- Apply Force: RR -->
      <plugin filename="gz-sim-apply-joint-force-system"
              name="gz::sim::systems::ApplyJointForce">
        <joint_name>spring_rr</joint_name>
      </plugin>

    </model>

  </world>
</sdf>
